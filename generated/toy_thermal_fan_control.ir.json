{
  "component": {
    "bus": {
      "mode": "preview",
      "type": "virtual",
      "wordBits": "16"
    },
    "name": "ToyThermalFanController",
    "parameters": {
      "coolingDuty": {
        "default": "80",
        "name": "coolingDuty",
        "type": "percent"
      },
      "fanOffThreshold": {
        "default": "65",
        "name": "fanOffThreshold",
        "type": "degC"
      },
      "fanOnThreshold": {
        "default": "75",
        "name": "fanOnThreshold",
        "type": "degC"
      },
      "safeDuty": {
        "default": "35",
        "name": "safeDuty",
        "type": "percent"
      }
    },
    "trace": [
      "STK-001",
      "SYS-001",
      "SYS-002",
      "SYS-003",
      "SYS-004",
      "SYS-005",
      "SYS-006",
      "SWE-001",
      "HAR-005"
    ]
  },
  "controls": [
    {
      "actions": {
        "fanDuty": "safeDuty",
        "fault": "true",
        "state": "FAULT"
      },
      "condition": "temperatureValid == false",
      "name": "sensorFault",
      "priority": 1000,
      "scenarios": [],
      "state_scope": "*",
      "trace": [
        "SYS-005",
        "HAR-004"
      ]
    },
    {
      "actions": {
        "fanDuty": "coolingDuty",
        "fault": "false",
        "state": "COOLING"
      },
      "condition": "temperatureC >= fanOnThreshold",
      "name": "highTemperature",
      "priority": 1001,
      "scenarios": [],
      "state_scope": "*",
      "trace": [
        "SYS-003",
        "SYS-006"
      ]
    },
    {
      "actions": {
        "fanDuty": "0",
        "fault": "false",
        "state": "IDLE"
      },
      "condition": "temperatureC <= fanOffThreshold",
      "name": "lowTemperature",
      "priority": 1002,
      "scenarios": [],
      "state_scope": "*",
      "trace": [
        "SYS-004",
        "SYS-006"
      ]
    }
  ],
  "flows": [
    {
      "label": "virtual sensor sample",
      "source": "ToyTempSensorIC.temperatureC",
      "target": "HAL_SPI.read_temperature",
      "trace": [
        "SYS-001",
        "HAR-001"
      ]
    },
    {
      "label": "HAL input",
      "source": "HAL_SPI.read_temperature",
      "target": "ToyThermalFanController.temperatureC",
      "trace": [
        "SWE-004",
        "HAR-002"
      ]
    },
    {
      "label": "generated ECU command",
      "source": "ToyThermalFanController.fanDuty",
      "target": "HAL_PWM.set_fan_duty",
      "trace": [
        "SYS-002",
        "SWE-004"
      ]
    },
    {
      "label": "virtual actuator command",
      "source": "HAL_PWM.set_fan_duty",
      "target": "ToyFanDriverIC.dutyCommand",
      "trace": [
        "SYS-002",
        "HAR-001"
      ]
    },
    {
      "label": "fault observation",
      "source": "ToyThermalFanController.fault",
      "target": "ScenarioReport.observedBehavior",
      "trace": [
        "SYS-006",
        "HAR-004"
      ]
    }
  ],
  "harness_devices": [
    {
      "boundary": "virtual_ic",
      "name": "ToyTempSensorIC",
      "role": "sensor",
      "trace": [
        "HAR-001",
        "SYS-001"
      ]
    },
    {
      "boundary": "virtual_ic",
      "name": "ToyFanDriverIC",
      "role": "actuator",
      "trace": [
        "HAR-001",
        "SYS-002"
      ]
    },
    {
      "boundary": "hal",
      "name": "ToyThermalFanController",
      "role": "controller",
      "trace": [
        "HAR-002",
        "SWE-004"
      ]
    }
  ],
  "metadata": {
    "irRole": "internal snapshot",
    "requirementRefs": [
      "HAR-001",
      "HAR-002",
      "HAR-004",
      "HAR-005",
      "STK-001",
      "SWE-001",
      "SWE-004",
      "SYS-001",
      "SYS-002",
      "SYS-003",
      "SYS-004",
      "SYS-005",
      "SYS-006"
    ],
    "sourceFormat": "mbd-markdown",
    "sourcePath": "examples/toy_thermal_fan_control.mbd.md"
  },
  "ports": {
    "fanDuty": {
      "default": "0",
      "direction": "out",
      "name": "fanDuty",
      "type": "percent"
    },
    "fault": {
      "default": "false",
      "direction": "out",
      "name": "fault",
      "type": "bool"
    },
    "temperatureC": {
      "default": "25",
      "direction": "in",
      "name": "temperatureC",
      "type": "degC"
    },
    "temperatureValid": {
      "default": "true",
      "direction": "in",
      "name": "temperatureValid",
      "type": "bool"
    }
  },
  "registers": {
    "FAN_COMMAND": {
      "access": "rw",
      "address": "0x20",
      "fields": {
        "commandValid": {
          "bit": 15,
          "bits": "15",
          "name": "commandValid",
          "reset": "0"
        },
        "dutyCommand": {
          "bit": 7,
          "bits": "7..0",
          "name": "dutyCommand",
          "reset": "0"
        }
      },
      "name": "FAN_COMMAND",
      "width": 16
    },
    "FAULT_STATUS": {
      "access": "ro",
      "address": "0x30",
      "fields": {
        "sensorInvalid": {
          "bit": 0,
          "bits": "0",
          "name": "sensorInvalid",
          "reset": "0"
        }
      },
      "name": "FAULT_STATUS",
      "width": 8
    },
    "TEMP_STATUS": {
      "access": "ro",
      "address": "0x10",
      "fields": {
        "temperatureRaw": {
          "bit": 14,
          "bits": "14..0",
          "name": "temperatureRaw",
          "reset": "25"
        },
        "valid": {
          "bit": 15,
          "bits": "15",
          "name": "valid",
          "reset": "1"
        }
      },
      "name": "TEMP_STATUS",
      "width": 16
    }
  },
  "sections": [
    {
      "body": "component ToyThermalFanController\ntrace STK-001 SYS-001 SYS-002 SYS-003 SYS-004 SYS-005 SYS-006 SWE-001 HAR-005\nbus virtual mode=preview wordBits=16\nparameter fanOnThreshold: degC = 75\nparameter fanOffThreshold: degC = 65\nparameter coolingDuty: percent = 80\nparameter safeDuty: percent = 35\n\nport in temperatureC: degC = 25\nport in temperatureValid: bool = true\nport out fanDuty: percent = 0\nport out fault: bool = false",
      "language": "mbd-component"
    },
    {
      "body": "TEMP_STATUS 0x10 ro 16\n  bit 15 valid reset=1\n  bits 14..0 temperatureRaw reset=25\n\nFAN_COMMAND 0x20 rw 16\n  bits 7..0 dutyCommand reset=0\n  bit 15 commandValid reset=0\n\nFAULT_STATUS 0x30 ro 8\n  bit 0 sensorInvalid reset=0",
      "language": "mbd-registers"
    },
    {
      "body": "RESET --> IDLE: powerOn\nIDLE --> COOLING: temperatureC >= fanOnThreshold\nCOOLING --> IDLE: temperatureC <= fanOffThreshold\nIDLE --> FAULT: temperatureValid == false\nCOOLING --> FAULT: temperatureValid == false\nFAULT --> IDLE: temperatureValid == true",
      "language": "mbd-state"
    },
    {
      "body": "ToyTempSensorIC.temperatureC -> HAL_SPI.read_temperature: virtual sensor sample trace SYS-001 HAR-001\nHAL_SPI.read_temperature -> ToyThermalFanController.temperatureC: HAL input trace SWE-004 HAR-002\nToyThermalFanController.fanDuty -> HAL_PWM.set_fan_duty: generated ECU command trace SYS-002 SWE-004\nHAL_PWM.set_fan_duty -> ToyFanDriverIC.dutyCommand: virtual actuator command trace SYS-002 HAR-001\nToyThermalFanController.fault -> ScenarioReport.observedBehavior: fault observation trace SYS-006 HAR-004",
      "language": "mbd-flow"
    },
    {
      "body": "rule sensorFault: when temperatureValid == false then state=FAULT, fanDuty=safeDuty, fault=true trace SYS-005 HAR-004\nrule highTemperature: when temperatureC >= fanOnThreshold then state=COOLING, fanDuty=coolingDuty, fault=false trace SYS-003 SYS-006\nrule lowTemperature: when temperatureC <= fanOffThreshold then state=IDLE, fanDuty=0, fault=false trace SYS-004 SYS-006",
      "language": "mbd-control"
    },
    {
      "body": "device ToyTempSensorIC role=sensor boundary=virtual_ic trace HAR-001 SYS-001\ndevice ToyFanDriverIC role=actuator boundary=virtual_ic trace HAR-001 SYS-002\necu ToyThermalFanController role=controller boundary=hal trace HAR-002 SWE-004",
      "language": "mbd-harness"
    }
  ],
  "source_path": "examples/toy_thermal_fan_control.mbd.md",
  "title": "Toy Thermal Fan Control",
  "transitions": [
    {
      "condition": "powerOn",
      "source": "RESET",
      "target": "IDLE"
    },
    {
      "condition": "temperatureC >= fanOnThreshold",
      "source": "IDLE",
      "target": "COOLING"
    },
    {
      "condition": "temperatureC <= fanOffThreshold",
      "source": "COOLING",
      "target": "IDLE"
    },
    {
      "condition": "temperatureValid == false",
      "source": "IDLE",
      "target": "FAULT"
    },
    {
      "condition": "temperatureValid == false",
      "source": "COOLING",
      "target": "FAULT"
    },
    {
      "condition": "temperatureValid == true",
      "source": "FAULT",
      "target": "IDLE"
    }
  ]
}
