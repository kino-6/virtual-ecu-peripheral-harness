{
  "component": "ToyThermalProtectionController",
  "controlRules": [
    {
      "actions": {
        "deratingCommand": "0",
        "diagnosticFault": "false",
        "fanDuty": "0",
        "safeCommandActive": "false",
        "state": "IDLE"
      },
      "condition": "temperatureValid == true and invalidDebounced == false and recoveryRequest == true",
      "name": "recoverFromLatch",
      "owner": "FaultLatchRecoveryManager",
      "priority": 10,
      "scenarios": [
        "thermal_protection_recovery"
      ],
      "stateScope": "FAULT_LATCHED",
      "trace": [
        "SYS-008",
        "HAR-006"
      ]
    },
    {
      "actions": {
        "deratingCommand": "0",
        "diagnosticFault": "true",
        "fanDuty": "safeDuty",
        "safeCommandActive": "true",
        "state": "FAULT_LATCHED"
      },
      "condition": "invalidDebounced == true",
      "name": "faultLatch",
      "owner": "FaultLatchRecoveryManager",
      "priority": 20,
      "scenarios": [
        "thermal_protection_fault_latch",
        "thermal_protection_recovery"
      ],
      "stateScope": "*",
      "trace": [
        "SYS-007",
        "SYS-006",
        "HAR-004"
      ]
    },
    {
      "actions": {
        "deratingCommand": "0",
        "diagnosticFault": "true",
        "fanDuty": "safeDuty",
        "safeCommandActive": "true",
        "state": "FAULT_LATCHED"
      },
      "condition": "always",
      "name": "holdLatchedFault",
      "owner": "FaultLatchRecoveryManager",
      "priority": 30,
      "scenarios": [
        "thermal_protection_fault_latch",
        "thermal_protection_recovery"
      ],
      "stateScope": "FAULT_LATCHED",
      "trace": [
        "SYS-007",
        "HAR-004"
      ]
    },
    {
      "actions": {
        "deratingCommand": "0",
        "diagnosticFault": "true",
        "fanDuty": "safeDuty",
        "safeCommandActive": "true",
        "state": "SENSOR_FAULT"
      },
      "condition": "temperatureValid == false",
      "name": "sensorInvalid",
      "owner": "FaultLatchRecoveryManager",
      "priority": 40,
      "scenarios": [
        "thermal_protection_fault_latch",
        "thermal_protection_recovery"
      ],
      "stateScope": "*",
      "trace": [
        "SYS-006",
        "HAR-004"
      ]
    },
    {
      "actions": {
        "deratingCommand": "deratingLimit",
        "diagnosticFault": "false",
        "fanDuty": "deratingFanDuty",
        "safeCommandActive": "false",
        "state": "DERATING"
      },
      "condition": "temperatureC >= deratingEntryThreshold",
      "name": "derating",
      "owner": "DeratingCommandManager",
      "priority": 50,
      "scenarios": [
        "thermal_protection_derating",
        "thermal_protection_recovery"
      ],
      "stateScope": "*",
      "trace": [
        "SYS-005",
        "SYS-002",
        "HAR-004"
      ]
    },
    {
      "actions": {
        "deratingCommand": "0",
        "diagnosticFault": "false",
        "fanDuty": "coolingDuty",
        "safeCommandActive": "false",
        "state": "COOLING"
      },
      "condition": "temperatureC >= coolingOnThreshold",
      "name": "highCooling",
      "owner": "CoolingCommandManager",
      "priority": 60,
      "scenarios": [
        "thermal_protection_normal"
      ],
      "stateScope": "*",
      "trace": [
        "SYS-003",
        "SYS-002",
        "HAR-004"
      ]
    },
    {
      "actions": {
        "deratingCommand": "0",
        "diagnosticFault": "false",
        "fanDuty": "0",
        "safeCommandActive": "false",
        "state": "IDLE"
      },
      "condition": "temperatureC <= coolingOffThreshold",
      "name": "lowCooling",
      "owner": "CoolingCommandManager",
      "priority": 70,
      "scenarios": [
        "thermal_protection_boundary"
      ],
      "stateScope": "*",
      "trace": [
        "SYS-004",
        "HAR-004"
      ]
    }
  ],
  "fmiIntent": "metadata stub only; no FMU is generated",
  "functionalDecomposition": [
    {
      "inputs": [
        "ToyTempSensorIC.temperatureC",
        "ToyTempSensorIC.temperatureValid"
      ],
      "name": "SensorInterface",
      "outputs": [
        "temperatureC",
        "temperatureValid"
      ],
      "owns": [
        "temperatureC",
        "temperatureValid"
      ],
      "responsibility": "Acquire fictional temperature and validity through the HAL boundary",
      "scenarios": [
        "thermal_protection_normal",
        "thermal_protection_derating",
        "thermal_protection_fault_latch",
        "thermal_protection_recovery"
      ],
      "trace": [
        "SYS-001",
        "HAR-001",
        "HAR-002"
      ]
    },
    {
      "inputs": [
        "temperatureValid",
        "ToyTempSensorIC.invalidDebounced"
      ],
      "name": "ValidityDebounceManager",
      "outputs": [
        "invalidDebounced"
      ],
      "owns": [
        "invalidDebounced"
      ],
      "responsibility": "Represent invalid sensor input and preview debounce status without timing physics",
      "scenarios": [
        "thermal_protection_fault_latch",
        "thermal_protection_recovery"
      ],
      "trace": [
        "SYS-006",
        "SYS-007",
        "ENG-002",
        "HAR-003"
      ]
    },
    {
      "inputs": [
        "temperatureC",
        "temperatureValid"
      ],
      "name": "ThermalStateManager",
      "outputs": [
        "state"
      ],
      "owns": [
        "IDLE",
        "COOLING",
        "DERATING"
      ],
      "responsibility": "Own IDLE COOLING and DERATING state decisions for valid temperature inputs",
      "scenarios": [
        "thermal_protection_normal",
        "thermal_protection_boundary",
        "thermal_protection_derating"
      ],
      "trace": [
        "SYS-003",
        "SYS-004",
        "SYS-005"
      ]
    },
    {
      "inputs": [
        "state",
        "temperatureC"
      ],
      "name": "CoolingCommandManager",
      "outputs": [
        "fanDuty"
      ],
      "owns": [
        "fanDuty"
      ],
      "responsibility": "Calculate nominal fan command for cooling and hysteresis behavior",
      "scenarios": [
        "thermal_protection_normal",
        "thermal_protection_boundary"
      ],
      "trace": [
        "SYS-002",
        "SYS-003",
        "SYS-004"
      ]
    },
    {
      "inputs": [
        "state",
        "temperatureC"
      ],
      "name": "DeratingCommandManager",
      "outputs": [
        "fanDuty",
        "deratingCommand"
      ],
      "owns": [
        "deratingCommand"
      ],
      "responsibility": "Calculate high-temperature fan and fictional load-limit commands",
      "scenarios": [
        "thermal_protection_derating"
      ],
      "trace": [
        "SYS-005"
      ]
    },
    {
      "inputs": [
        "temperatureValid",
        "invalidDebounced",
        "recoveryRequest"
      ],
      "name": "FaultLatchRecoveryManager",
      "outputs": [
        "state",
        "safeCommandActive",
        "diagnosticFault"
      ],
      "owns": [
        "SENSOR_FAULT",
        "FAULT_LATCHED",
        "recoveryRequest"
      ],
      "responsibility": "Own sensor fault latch hold and explicit recovery behavior",
      "scenarios": [
        "thermal_protection_fault_latch",
        "thermal_protection_recovery"
      ],
      "trace": [
        "SYS-006",
        "SYS-007",
        "SYS-008"
      ]
    },
    {
      "inputs": [
        "fanDuty",
        "deratingCommand",
        "state"
      ],
      "name": "OutputMappingDiagnostics",
      "outputs": [
        "HAL_PWM.set_fan_duty",
        "HAL_LIMITER.set_derating",
        "ScenarioReport.observedBehavior",
        "ScenarioReport.passFailResult"
      ],
      "owns": [
        "safeCommandActive",
        "diagnosticFault"
      ],
      "responsibility": "Map selected commands to HAL outputs and report-observable diagnostics",
      "scenarios": [
        "thermal_protection_normal",
        "thermal_protection_boundary",
        "thermal_protection_derating",
        "thermal_protection_fault_latch",
        "thermal_protection_recovery"
      ],
      "trace": [
        "SYS-002",
        "SYS-006",
        "SYS-009",
        "CGEN-003",
        "HAR-004"
      ]
    }
  ],
  "harnessDevices": [
    {
      "boundary": "virtual_ic",
      "name": "ToyTempSensorIC",
      "role": "sensor",
      "trace": [
        "HAR-001",
        "SYS-001",
        "SYS-006",
        "SYS-007"
      ]
    },
    {
      "boundary": "virtual_ic",
      "name": "ToyFanDriverIC",
      "role": "actuator",
      "trace": [
        "HAR-001",
        "SYS-002"
      ]
    },
    {
      "boundary": "virtual_ic",
      "name": "ToyLoadLimiterIC",
      "role": "actuator",
      "trace": [
        "HAR-006",
        "SYS-005"
      ]
    },
    {
      "boundary": "hal",
      "name": "ToyThermalProtectionController",
      "role": "controller",
      "trace": [
        "HAR-002",
        "SWE-004",
        "CGEN-003"
      ]
    }
  ],
  "inputs": [
    {
      "default": "25",
      "name": "temperatureC",
      "type": "degC"
    },
    {
      "default": "true",
      "name": "temperatureValid",
      "type": "bool"
    },
    {
      "default": "false",
      "name": "invalidDebounced",
      "type": "bool"
    },
    {
      "default": "false",
      "name": "recoveryRequest",
      "type": "bool"
    }
  ],
  "outputs": [
    {
      "default": "0",
      "name": "fanDuty",
      "type": "percent"
    },
    {
      "default": "0",
      "name": "deratingCommand",
      "type": "percent"
    },
    {
      "default": "false",
      "name": "diagnosticFault",
      "type": "bool"
    },
    {
      "default": "false",
      "name": "safeCommandActive",
      "type": "bool"
    }
  ],
  "parameters": [
    {
      "default": "78",
      "name": "coolingOnThreshold",
      "type": "degC"
    },
    {
      "default": "68",
      "name": "coolingOffThreshold",
      "type": "degC"
    },
    {
      "default": "94",
      "name": "deratingEntryThreshold",
      "type": "degC"
    },
    {
      "default": "70",
      "name": "coolingDuty",
      "type": "percent"
    },
    {
      "default": "95",
      "name": "deratingFanDuty",
      "type": "percent"
    },
    {
      "default": "45",
      "name": "deratingLimit",
      "type": "percent"
    },
    {
      "default": "30",
      "name": "safeDuty",
      "type": "percent"
    }
  ],
  "registers": [
    {
      "access": "ro",
      "address": "0x10",
      "name": "TP_TEMP_STATUS"
    },
    {
      "access": "ro",
      "address": "0x20",
      "name": "TP_CONTROL_STATUS"
    },
    {
      "access": "rw",
      "address": "0x30",
      "name": "TP_COMMAND"
    }
  ],
  "requirementRefs": [
    "CGEN-003",
    "ENG-002",
    "HAR-001",
    "HAR-002",
    "HAR-003",
    "HAR-004",
    "HAR-006",
    "SWE-001",
    "SWE-002",
    "SWE-003",
    "SWE-004",
    "SYS-001",
    "SYS-002",
    "SYS-003",
    "SYS-004",
    "SYS-005",
    "SYS-006",
    "SYS-007",
    "SYS-008",
    "SYS-009"
  ],
  "source": "samples/thermal_protection_controller/model.mbd.md",
  "sourceFormat": "mbd-markdown",
  "states": [
    "RESET",
    "IDLE",
    "COOLING",
    "DERATING",
    "SENSOR_FAULT",
    "FAULT_LATCHED"
  ]
}
