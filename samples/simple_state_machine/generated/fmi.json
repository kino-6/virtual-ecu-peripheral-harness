        "complete"
      ],
      "owns": [
        "IDLE",
        "RUNNING",
        "DONE",
        "busy",
        "complete"
      ],
      "responsibility": "Own the IDLE/RUNNING/DONE lifecycle and map state transitions to busy and complete outputs",
