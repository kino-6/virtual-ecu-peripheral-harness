{
  "component": "ToyStateMachine",
  "controlRules": [
    {
      "actions": {
        "busy": "true",
        "complete": "false",
        "state": "RUNNING"
      },
      "condition": "startCommand == true",
      "name": "start_running",
      "owner": "ToyStateController",
      "priority": 10,
      "scenarios": [
        "full_cycle"
      ],
      "stateScope": "IDLE",
      "trace": [
        "SM-001",
        "SM-004"
      ]
    },
    {
      "actions": {
        "busy": "false",
        "complete": "true",
        "state": "DONE"
      },
      "condition": "finishCommand == true",
      "name": "finish_done",
      "owner": "ToyStateController",
      "priority": 20,
      "scenarios": [
        "full_cycle"
      ],
      "stateScope": "RUNNING",
      "trace": [
        "SM-002",
        "SM-004"
      ]
    },
    {
      "actions": {
        "busy": "false",
        "complete": "false",
        "state": "IDLE"
      },
      "condition": "resetCommand == true",
      "name": "reset_idle",
      "owner": "ToyStateController",
      "priority": 30,
      "scenarios": [
        "full_cycle"
      ],
      "stateScope": "DONE",
      "trace": [
        "SM-003",
        "SM-004"
      ]
    }
  ],
  "fmiIntent": "metadata stub only; no FMU is generated",
