  "sections": [
    {
      "body": "component ToyStateMachine\ntrace SM-001 SM-002 SM-003 SM-004\nbus virtual mode=preview wordBits=8\n\nport in startCommand: bool = false\nport in finishCommand: bool = false\nport in resetCommand: bool = false\nport out busy: bool = false\nport out complete: bool = false",
      "language": "mbd-component"
    },
    {
      "body": "STATUS 0x01 ro 8\n  bit 0 busy reset=0\n  bit 1 complete reset=0",
      "language": "mbd-registers"
    },
    {
      "body": "IDLE --> RUNNING: startCommand == true\nRUNNING --> DONE: finishCommand == true\nDONE --> IDLE: resetCommand == true",
      "language": "mbd-state"
    },
    {
      "body": "function ToyStateController: responsibility=Own the IDLE/RUNNING/DONE lifecycle and map state transitions to busy and complete outputs; owns=IDLE,RUNNING,DONE,busy,complete; inputs=startCommand,finishCommand,resetCommand; outputs=state,busy,complete; trace=SM-001,SM-002,SM-003,SM-004; scenarios=full_cycle",
      "language": "mbd-decomposition"
    },
    {
      "body": "ToyCommandSource.startCommand -> ToyStateController.startCommand: start request trace SM-001\nToyCommandSource.finishCommand -> ToyStateController.finishCommand: finish request trace SM-002\nToyCommandSource.resetCommand -> ToyStateController.resetCommand: reset request trace SM-003\nToyStateController.busy -> ToyStateMachine.busy: busy command trace SM-001 SM-002 SM-003\nToyStateController.complete -> ToyStateMachine.complete: completion command trace SM-002 SM-003\nToyStateMachine.busy -> ScenarioReport.observedBehavior: reported busy output trace SM-004\nToyStateMachine.complete -> ScenarioReport.observedBehavior: reported complete output trace SM-004",
      "language": "mbd-flow"
    },
    {
      "body": "priority 10 rule start_running: owner ToyStateController from IDLE when startCommand == true then state=RUNNING, busy=true, complete=false trace SM-001 SM-004 scenarios full_cycle\npriority 20 rule finish_done: owner ToyStateController from RUNNING when finishCommand == true then state=DONE, busy=false, complete=true trace SM-002 SM-004 scenarios full_cycle\npriority 30 rule reset_idle: owner ToyStateController from DONE when resetCommand == true then state=IDLE, busy=false, complete=false trace SM-003 SM-004 scenarios full_cycle",
      "language": "mbd-control"
    },
    {
      "body": "device ToyCommandSource role=source boundary=virtual_ic trace SM-001 SM-002 SM-003\necu ToyStateMachine role=controller boundary=hal trace SM-001 SM-002 SM-003 SM-004",
      "language": "mbd-harness"
    }
