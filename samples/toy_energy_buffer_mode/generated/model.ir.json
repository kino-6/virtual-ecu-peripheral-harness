  "sections": [
    {
      "body": "component ToyEnergyBufferMode\ntrace EBUF-001 EBUF-002 EBUF-003 EBUF-004 EBUF-005 EBUF-006\nbus virtual mode=preview wordBits=8\n\nport in externalPowerAvailable: bool = true\nport in emptyDetected: bool = false\nport out supplyEnabled: bool = false\nport out chargeIndicator: bool = true",
      "language": "mbd-component"
    },
    {
      "body": "STATUS 0x01 ro 8\n  bit 0 supplyEnabled reset=0\n  bit 1 chargeIndicator reset=1",
      "language": "mbd-registers"
    },
    {
      "body": "CHARGE --> DISCHARGE: externalPowerAvailable == false and emptyDetected == false\nDISCHARGE --> EMPTY: emptyDetected == true\nEMPTY --> CHARGE: externalPowerAvailable == true\nDISCHARGE --> CHARGE: externalPowerAvailable == true",
      "language": "mbd-state"
    },
    {
      "body": "function ToyEnergyBufferModeController: responsibility=Own the CHARGE/DISCHARGE/EMPTY lifecycle and map source availability plus empty detection to supply and charge indication outputs; owns=CHARGE,DISCHARGE,EMPTY,supplyEnabled,chargeIndicator; inputs=externalPowerAvailable,emptyDetected; outputs=state,supplyEnabled,chargeIndicator; trace=EBUF-001,EBUF-002,EBUF-003,EBUF-004,EBUF-005,EBUF-006; scenarios=source_loss_recovery",
      "language": "mbd-decomposition"
    },
    {
      "body": "ToyPowerSource.externalPowerAvailable -> ToyEnergyBufferModeController.externalPowerAvailable: source availability trace EBUF-001 EBUF-003 EBUF-004 EBUF-005\nToyEmptyMonitor.emptyDetected -> ToyEnergyBufferModeController.emptyDetected: empty indication trace EBUF-001 EBUF-002 EBUF-005\nToyEnergyBufferModeController.supplyEnabled -> ToyEnergyBufferMode.supplyEnabled: supply command trace EBUF-001 EBUF-002 EBUF-003 EBUF-004 EBUF-005\nToyEnergyBufferModeController.chargeIndicator -> ToyEnergyBufferMode.chargeIndicator: charge indication trace EBUF-001 EBUF-002 EBUF-003 EBUF-004 EBUF-005\nToyEnergyBufferMode.supplyEnabled -> ScenarioReport.observedBehavior: reported supply command trace EBUF-006\nToyEnergyBufferMode.chargeIndicator -> ScenarioReport.observedBehavior: reported charge indication trace EBUF-006",
      "language": "mbd-flow"
    },
    {
      "body": "priority 10 rule power_removed_discharge: owner ToyEnergyBufferModeController from CHARGE when externalPowerAvailable == false and emptyDetected == false then state=DISCHARGE, supplyEnabled=true, chargeIndicator=false trace EBUF-001 EBUF-006 scenarios source_loss_recovery\npriority 20 rule discharge_empty: owner ToyEnergyBufferModeController from DISCHARGE when emptyDetected == true then state=EMPTY, supplyEnabled=false, chargeIndicator=false trace EBUF-002 EBUF-006 scenarios source_loss_recovery\npriority 30 rule empty_reconnect_charge: owner ToyEnergyBufferModeController from EMPTY when externalPowerAvailable == true then state=CHARGE, supplyEnabled=false, chargeIndicator=true trace EBUF-003 EBUF-006 scenarios source_loss_recovery\npriority 40 rule discharge_reconnect_charge: owner ToyEnergyBufferModeController from DISCHARGE when externalPowerAvailable == true then state=CHARGE, supplyEnabled=false, chargeIndicator=true trace EBUF-004 EBUF-006 scenarios source_loss_recovery",
      "language": "mbd-control"
    },
    {
      "body": "device ToyPowerSource role=source boundary=virtual_ic trace EBUF-001 EBUF-003 EBUF-004 EBUF-005\ndevice ToyEmptyMonitor role=source boundary=virtual_ic trace EBUF-001 EBUF-002 EBUF-005\necu ToyEnergyBufferMode role=controller boundary=hal trace EBUF-001 EBUF-002 EBUF-003 EBUF-004 EBUF-005 EBUF-006",
