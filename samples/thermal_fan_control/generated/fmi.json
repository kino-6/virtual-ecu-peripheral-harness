{
  "component": "ToyThermalFanController",
  "controlRules": [
    {
      "actions": {
        "fanDuty": "safeDuty",
        "fault": "true",
        "state": "FAULT"
      },
      "condition": "temperatureValid == false",
      "name": "sensorFault",
      "owner": "",
      "priority": 1000,
      "scenarios": [],
      "stateScope": "*",
      "trace": [
        "SYS-005",
        "HAR-004"
      ]
    },
    {
      "actions": {
        "fanDuty": "coolingDuty",
        "fault": "false",
        "state": "COOLING"
      },
      "condition": "temperatureC >= fanOnThreshold",
      "name": "highTemperature",
      "owner": "",
      "priority": 1001,
      "scenarios": [],
      "stateScope": "*",
      "trace": [
        "SYS-003",
        "SYS-006"
      ]
    },
    {
      "actions": {
        "fanDuty": "0",
        "fault": "false",
        "state": "IDLE"
      },
      "condition": "temperatureC <= fanOffThreshold",
      "name": "lowTemperature",
      "owner": "",
      "priority": 1002,
      "scenarios": [],
      "stateScope": "*",
      "trace": [
        "SYS-004",
        "SYS-006"
      ]
    }
  ],
